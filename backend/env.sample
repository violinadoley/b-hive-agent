# Copy to .env (never commit .env)
# Docs: agents/README.md, docs/Integration-and-Build-Guide.md

# --- Hedera testnet operator (Hedera Agent Kit / SDK) ---
ACCOUNT_ID=0.0.xxxxx
ECDSA_PRIVATE_KEY=0x...
# PRIVATE_KEY=   # optional alias

# Optional: mirrors Mirror REST `evm_address` for Bonzo / EVM calls
# ECDSA_EVM_ADDRESS=0x...

# --- Bonzo Lend Data API (HTTP — no API key in public docs) ---
# Prod base (documented): https://docs.bonzo.finance/hub/developer/bonzo-lend/lend-data-api
BONZO_DATA_API_BASE=https://data.bonzo.finance
# If prod errors, Bonzo may still document a temporary host — keep as fallback
BONZO_DATA_API_FALLBACK=https://mainnet-data-staging.bonzo.finance

# Bonzo LendingPool (EVM) — MUST match HEDERA_CHAIN_ID + JSON-RPC network.
# Testnet default from https://docs.bonzo.finance/hub/developer/bonzo-lend/lend-contracts
# BONZO_LENDING_POOL_ADDRESS=0xf67DBe9bD1B331cA379c44b5562EAa1CE831EbC2

# --- Hedera Mirror Node REST (testnet) ---
# https://docs.hedera.com/hedera/sdks-and-apis/rest-api
HEDERA_MIRROR_REST_BASE=https://testnet.mirrornode.hedera.com/api/v1

# --- Hedera JSON-RPC (Hashio testnet) — execution / ethers later ---
# https://docs.hedera.com/hedera/core-concepts/smart-contracts/json-rpc-relay
HEDERA_JSON_RPC_URL=https://testnet.hashio.io/api
HEDERA_CHAIN_ID=296

# --- LLM (optional smoke step) ---
GROQ_API_KEY=
# Optional override for strategy reasoner model:
# GROQ_MODEL=llama-3.3-70b-versatile

# --- API server runtime ---
# API_PORT=4000
# STREAM_POLL_MS=1500

# --- Orchestrator observability + Hedera verifiability ---
# L1 decision event store path (relative to agents/)
# DECISION_LOG_PATH=data/decision-events.jsonl
# HCS topic for attested run commitments (required to submit on Hedera)
# HCS_TOPIC_ID=0.0.xxxxx
# Live monitor loop
# MONITOR_INTERVAL_SECONDS=300
# EXTERNAL_CONTEXT_EVERY_N_RUNS=2
# FORCE_STRATEGY_EVERY_N_RUNS=6
# MAX_RUNS_PER_DAY=240

# --- External context APIs (real data sources) ---
# GNEWS_API_KEY=    # required for live_crypto_news tool
# GNEWS_BASE_URL=https://gnews.io/api/v4
# DEFILLAMA_BASE_URL=https://api.llama.fi
# FEAR_GREED_API_BASE=https://api.alternative.me

# --- Bonzo Vault keeper scope (must be real addresses) ---
# BONZO_VAULT_ADDRESS=0x...
# BONZO_VAULT_STRATEGY_ADDRESS=0x...

# --- Telegram bot (monitor process) ---
# TELEGRAM_BOT_TOKEN=123456789:ABCDEF...
# Allow everyone to use commands + router (recommended for demos). Values: 1, true, yes
# TELEGRAM_ALLOW_ALL=true
# Optional allowlist (comma-separated chat ids). Used when TELEGRAM_ALLOW_ALL is not set.
# If unset and empty file: anyone can chat until the first /start writes telegram-allowed-ids.json (then only listed ids).
# TELEGRAM_ALLOWED_CHAT_IDS=
# Generated by you (e.g. `openssl rand -hex 32`) and validated against Telegram webhook header
# TELEGRAM_WEBHOOK_SECRET=

# --- RAG (Qdrant + embeddings) ---
# LangChain tool `b_hive_docs_rag_search` is registered when QDRANT_URL is set.
# Prefer Gemini: https://ai.google.dev/api/embeddings (model gemini-embedding-001, 1536-dim output)
# GEMINI_API_KEY=
# Or fallback OpenAI: OPENAI_API_KEY=  (text-embedding-3-small, 1536-dim)
# GOOGLE_API_KEY=   # optional alias read if GEMINI_API_KEY unset
# QDRANT_URL=https://xxxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=   # Qdrant Cloud API key if required
# QDRANT_COLLECTION=b_hive_knowledge
